# CineAI Environment Variables

# Supabase (public — safe for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side — used by Edge Functions)
# These go in Vercel Edge Function environment variables
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Vertex AI (server-only — never expose to frontend)
# VERTEX_AI_KEY=your-vertex-api-key
# VERTEX_PROJECT_ID=your-gcp-project-id
